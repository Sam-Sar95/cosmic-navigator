{
  "version": 2,
  "buildCommand": "pnpm build && npx expo export --platform web --output dist/web",
  "outputDirectory": "dist/web",
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:3000/api/$1"
    },
    {
      "source": "/trpc/(.*)",
      "destination": "http://localhost:3000/trpc/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
